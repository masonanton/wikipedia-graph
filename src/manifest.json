{
  "manifest_version": 3,
  "name": "Wikipedia Graph",
  "version": "0.1.0",
  "description": "Visualize Wikipedia article links as a force-directed graph.",
  "permissions": ["storage", "activeTab", "sidePanel"],
  "host_permissions": ["https://*.wikipedia.org/*"],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://*.wikipedia.org/wiki/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "popup.html",
    "default_title": "Wikipedia Graph"
  },
  "web_accessible_resources": [
    {
      "resources": ["graph.html", "graph.js"],
      "matches": ["https://*.wikipedia.org/*"]
    }
  ]
}
